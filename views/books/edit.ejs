<body>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <%- include('../partials/nav.ejs') %>

    <main class="form-page">

    <h1>Edit Book</h1>

    <form action="/books/<%= foundBook._id %>?_method=PUT" method="POST">
  Title:
  <input
    type="text"
    name="title"
    value="<%= foundBook.title %>"
    required
  />
  Author:
  <input 
  type="text" 
  name="author"
  value="<%= foundBook.author %>"
  required
  />
  Description:
  <textarea
    name="description"
    rows="6"
    required
><%= foundBook.description %></textarea>

<br/>

  Cover Image:
  <input
    type="text"
    name="coverImage"
    value="<%= foundBook.coverImage %>"
    required
  />

  <button type="submit">Save Changes</button>

</form>

</main>
</body>