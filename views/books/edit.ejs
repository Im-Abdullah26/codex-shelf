<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <%- include('../partials/nav.ejs') %>
    <h1>Edit Book</h1>

    <form action="/books/<%= foundBook._id %>?_method=PUT" method="POST">
  Title:
  <input
    type="text"
    name="title"
    value="<%= foundBook.title %>"
  />
  Author:
  <input 
  type="text" 
  name="author"
  value="<%= foundBook.author %>" 
  />
  Description:
  <textarea
    type="text"
    name="description"
    rows="6"
><%= foundBook.description %></textarea>
<br/>
  Cover Image:
  <input
    type="text"
    name="coverImage"
    value="<%= foundBook.coverImage %>"
  />
  <button type="submit">Save Changes</button>

</form>
</body>
</html>