<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon.ico.png"/>
    <%- include('./partials/nav.ejs') %>
    <title>Dashboard</title>
</head>
<body>
    <h1><%= user.username %>'s Dashboard</h1>
    <main class="dashboard">

<h1>📚 Dashboard</h1>

<p>Welcome back, <%= user.username %>!</p>

<div class="dashboard-actions">

    <a href="/books" class="button">Browse Books</a>

    <a href="/books/new" class="button">Add Book</a>

    <form action="/auth/sign-out?_method=DELETE" method="POST">
        <button class="danger-button">Sign Out</button>
    </form>

</div>

</main>
</body>
</html>